<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name control_center.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="ControlCenterPluginControlCenter" parent="GtkPopover">
    <property name="cascade-popdown">True</property>
    <property name="has-arrow">False</property>
    <child>
      <object class="GtkRevealer">
        <child>
          <object class="AdwViewStack" id="status_view_stack">
            <property name="margin-bottom">15</property>
            <property name="margin-end">15</property>
            <property name="margin-start">15</property>
            <property name="margin-top">3</property>
            <child>
              <object class="AdwViewStackPage">
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="AdwViewStack" id="view_stack">
                        <property name="enable-transitions">True</property>
                        <property name="margin-bottom">15</property>
                        <property name="vexpand">True</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwInlineViewSwitcher">
                        <property name="css-classes">round</property>
                        <property name="display-mode">both</property>
                        <property name="stack">view_stack</property>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="name">settings</property>
              </object>
            </child>
            <child>
              <object class="AdwViewStackPage">
                <property name="child">
                  <object class="AdwStatusPage">
                    <property name="css-classes">compact</property>
                    <property name="description">Please check your hardware</property>
                    <property name="icon-name">action-unavailable-symbolic</property>
                    <property name="title">No settings available</property>
                  </object>
                </property>
                <property name="name">error</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
