<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name power_page.ui -->
  <requires lib="gtk" version="4.18"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="ControlCenterPluginPowerPage" parent="AdwBin">
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="AdwPreferencesGroup" id="profiles_group">
            <property name="title" translatable="yes">Power profile</property>
            <property name="vexpand">True</property>
          </object>
        </child>
        <child>
          <object class="AdwActionRow" id="battery_row">
            <property name="css-classes">card</property>
            <property name="subtitle" translatable="yes">Enough for %s</property>
            <property name="title" translatable="yes">Battery %d%</property>
            <property name="valign">end</property>
            <property name="visible">False</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
