<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="together-shell">
  <enum id="com.github.ZzEdovec.TogetherShell.PanelPosition">
    <value nick="top" value="0"/>
    <value nick="bottom" value="1"/>
    <value nick="left" value="2"/>
    <value nick="right" value="3"/>
  </enum>
  <enum id="com.github.ZzEdovec.TogetherShell.PanelAlignment">
    <value nick="start" value="0"/>
    <value nick="center" value="1"/>
    <value nick="end" value="2"/>
  </enum>
  <enum id="com.github.ZzEdovec.TogetherShell.BackgroundFit">
    <value nick="fill" value="0"/>
    <value nick="contain" value="1"/>
    <value nick="cover" value="2"/>
    <value nick="scale-down" value="3"/>
  </enum>

  <schema id="com.github.ZzEdovec.TogetherShell.Panel">
    <key name="position" enum="com.github.ZzEdovec.TogetherShell.PanelPosition">
      <default>'bottom'</default>
    </key>
    <key name="alignment" enum="com.github.ZzEdovec.TogetherShell.PanelAlignment">
      <default>'center'</default>
    </key>
    <key name="size" type="u">
      <default>48</default>
    </key>
    <key name="dock-mode" type="b">
      <default>false</default>
    </key>
    <key name="plugins" type="as">
      <default>['window-list']</default>
    </key>
  </schema>

	<schema id="com.github.ZzEdovec.TogetherShell" path="/com/github/ZzEdovec/TogetherShell/">
    <key name="panels" type="as">
      <default>[]</default>
    </key>
	  <key name="opacity" type="b">
	    <default>true</default>
	  </key>
	  <key name="window-list-labels" type="b">
	    <default>true</default>
	  </key>
	  <key name="window-list-group" type="b">
	    <default>true</default>
	  </key>
	  <key name="panel-pinned" type="as">
	    <default>['opera.desktop','org.gnome.Nautilus.desktop','com.ayugram.desktop.desktop','org.gnome.Console.desktop','net.nokyan.Resources.desktop','steam.desktop','']</default>
      <summary>Panel pinned apps</summary>
    </key>
	  <key name="appmenu-pinned" type="as">
	    <default>[]</default>
      <summary>Application menu pinned apps</summary>
    </key>
	  <key name="background" type="s">
	    <default>'/home/queinu/Изображения/together-shell/background.jpg'</default>
	    <summary>Background image path</summary>
	  </key>
	  <key name="background-fit" enum="com.github.ZzEdovec.TogetherShell.BackgroundFit">
	    <default>'fill'</default>
	  </key>
	</schema>
</schemalist>

